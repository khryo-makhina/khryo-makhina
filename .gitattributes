# Default: auto-detect text files, normalize to LF in repo, convert to CRLF on checkout (Windows)
* text=auto

# Windows-native development files (CRLF)
*.cs        text eol=crlf
*.csproj    text eol=crlf
*.sln       text eol=crlf
*.config    text eol=crlf
*.props     text eol=crlf
*.targets   text eol=crlf

# Cross-platform / tooling files (LF)
*.md        text eol=lf
*.txt       text eol=lf
*.json      text eol=lf
*.xml       text eol=lf
*.yml       text eol=lf
*.yaml      text eol=lf
*.js        text eol=lf
*.sh        text eol=lf
*.bash      text eol=lf
Dockerfile* text eol=lf

# Binary files
*.png       binary
*.jpg       binary
*.jpeg      binary
*.gif       binary
*.ico       binary
*.dll       binary
*.exe       binary
*.zip       binary
*.csv       binary

