<Window x:Class="MediaRenamer.WpfApp.MainWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
        xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
        mc:Ignorable="d"
        Title="Media Renamer" Height="500" Width="800">
    <DockPanel Margin="10">
        <StackPanel DockPanel.Dock="Top" Margin="0,0,0,10">
            <StackPanel Orientation="Horizontal" Margin="0,0,0,5">
                <TextBlock Text="Folder:" VerticalAlignment="Center" Width="60"/>
                <TextBox x:Name="FolderTextBox" Width="500" Margin="5,0,5,0"/>
                <Button Content="Browse..." Width="80" Click="Browse_Click"/>
            </StackPanel>
            <StackPanel Orientation="Horizontal" Margin="0,0,0,5">
                <TextBlock Text="Pattern:" VerticalAlignment="Center" Width="60"/>
                <TextBox x:Name="PatternTextBox" Width="200" Text="yyyyMMdd_HHmmss"/>
                <CheckBox x:Name="DryRunCheckBox" Content="Dry run" Margin="20,0,0,0" IsChecked="True"/>
            </StackPanel>
            <StackPanel Orientation="Horizontal">
                <Button Content="Scan" Width="80" Margin="0,0,5,0" Click="Scan_Click"/>
                <Button Content="Rename" Width="80" Click="Rename_Click"/>
                <TextBlock x:Name="StatusTextBlock" Margin="20,0,0,0" VerticalAlignment="Center"/>
            </StackPanel>
        </StackPanel>
        <DataGrid x:Name="PlanGrid" AutoGenerateColumns="False" IsReadOnly="True">
            <DataGrid.Columns>
                <DataGridTextColumn Header="Original" Binding="{Binding OriginalName}" Width="*"/>
                <DataGridTextColumn Header="New Name" Binding="{Binding NewName}" Width="*"/>
                <DataGridTextColumn Header="Reason" Binding="{Binding Reason}" Width="150"/>
            </DataGrid.Columns>
        </DataGrid>
    </DockPanel>
</Window>
